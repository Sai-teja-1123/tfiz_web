rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - category: string (required, enum: Apparel, Accessories, Digital)
    //   - image: string (required)
    //   - description: string (required)
    //   - isLimited: boolean (optional)
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - userEmail: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required, enum: pending, completed, cancelled)
    //   - createdAt: timestamp (required)
    //   - shippingAddress: map (required)
    //
    // Collection: subscribers
    // Document ID: auto-generated
    // Fields:
    //   - email: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, enum: admin, client)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nutanvenu@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category in ['Apparel', 'Accessories', 'Digital'] &&
             data.image is string && data.image.size() > 0 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000;
    }

    function isValidOrder(data) {
      return (data.userId == request.auth.uid || data.userId == 'anonymous') &&
             data.userEmail is string && data.userEmail.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.createdAt is timestamp &&
             data.shippingAddress is map &&
             data.shippingAddress.firstName is string &&
             data.shippingAddress.lastName is string &&
             data.shippingAddress.address is string &&
             data.shippingAddress.city is string &&
             data.shippingAddress.zipCode is string;
    }

    function isValidSubscriber(data) {
      return data.email is string && data.email.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.email is string &&
             data.role in ['admin', 'client'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if (isAuthenticated() || request.resource.data.userId == 'anonymous') && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /subscribers/{subscriberId} {
      allow read: if isAdmin();
      allow create: if isValidSubscriber(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'client';
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
